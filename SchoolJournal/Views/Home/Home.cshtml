@model List<JournalListContent>
@{
    Layout = "_MainLayout";
    ViewBag.Title = "Головна сторінка";
}
<div class="mt-3">
    <h2 class="text-center text-dark mb-3">Список доступних журналів</h2>
    @if(Context.Session.GetString("Status") == "Admin")
    {
        <form method="post" class="row g-3 mb-3 ms-3">
            <div class="col-auto">
                <span>За предметами: </span> 
            </div>
            <div class="col-auto">
                @Html.DropDownList("subjectId", ((SelectList)ViewBag.SubjectsSelectList), "Всі предмети", 
                new { @class = "form-select form-select-sm text-center mr-3" })                                      
            </div> 
            <div class="col-auto">
                <span>За класами: </span> 
            </div>
            <div class="col-auto">
                @Html.DropDownList("classRangId", ((SelectList)ViewBag.ClassRanksSelectList), "Всі класи", 
                new { @class = "form-select form-select-sm text-center mr-3" })
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-link" style="color:#52796f">Застосувати фільтри</button>
            </div>
        </form>     
    }
    else
    {
        
    }
    <table class="table table-striped table-borderless">
        <thead style="background-color:#cad2c5;" class="text-dark text-center">
            <tr>
                <th>Предмет</th>
                <th>Клас</th>
                <th>Вчитель</th>
                <th></th>
            </tr>
        </thead>
        <tbody class="text-dark text-center">
            @foreach(JournalListContent j in Model)
            {
                <tr>
                    <td>@j.Subject.Title</td>
                    <td>@j.Class.Title</td>
                    <td>@j.Teacher.Surname @j.Teacher.Name @j.Teacher.Middlename</td>
                    <td><a asp-controller="Journal" asp-action="Journal" asp-route-journalId="@j.Journal.Id"
                        class="btn btn-sm" style="background-color:#2F3E46; color:#CAD2C5">Переглянути</a></td>
                </tr>                
            }
        </tbody>
    </table>
</div>
    



