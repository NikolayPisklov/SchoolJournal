@model List<JournalListContent>
@{
    Layout = "_MainLayout";
    ViewBag.Title = "Головна сторінка";
}
<div class="mt-3">
    <h2 class="text-center text-dark mb-3">Список доступних журналів</h2>
    <table class="table table-striped">
        <thead style="background-color:#D90429" class="text-light text-center">
            <tr>
                <th>Предмет</th>
                <th>Клас</th>
                <th>Вчитель</th>
                <th></th>
            </tr>
        </thead>
        <tbody class="text-dark text-center">
            @foreach(JournalListContent j in Model)
            {
                <tr>
                    <td>@j.Subject.Title</td>
                    <td>@j.Class.Title</td>
                    <td>@j.Teacher.Surname @j.Teacher.Name @j.Teacher.Middlename</td>
                    <td><a class="btn btn-sm text-light" style="background-color:#D90429">Переглянути</a></td>
                </tr>                
            }
        </tbody>
    </table>
</div>
    



